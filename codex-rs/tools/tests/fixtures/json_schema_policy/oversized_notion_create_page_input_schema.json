                  {
                    "type": "object",
                    "properties": {
                      "checked": {
                        "type": "boolean"
                      }
                    },
                    "additionalProperties": true
                  }
                ]
              },
              "callout": {
                "allOf": [
                  {
                    "$ref": "#/$defs/text_block_payload"
