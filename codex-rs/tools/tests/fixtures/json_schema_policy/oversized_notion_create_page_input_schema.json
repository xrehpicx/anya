              },
              "url": {
                "type": "object",
                "additionalProperties": true
              },
              "email": {
                "type": "object",
                "additionalProperties": true
              },
              "phone_number": {
                "type": "object",
                "additionalProperties": true
              },
              "formula": {
                "type": "object",
                "additionalProperties": true
              },
              "relation": {
                "type": "object",
                "additionalProperties": true
              },
              "rollup": {
