                    "type": "array",
                    "items": {
                      "$ref": "#/$defs/rich_text"
                    }
                  },
                  "type": {
                    "type": "string"
                  },
                  "file": {
                    "$ref": "#/$defs/file_ref"
                  },
                  "external": {
                    "type": "object",
                    "properties": {
