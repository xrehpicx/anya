        {
          "$ref": "#/definitions/ThreadGoalStatus"
        },
        {
          "type": "null"
        }
      ]
    },
    "threadId": {
      "type": "string"
    },
    "tokenBudget": {
      "format": "int64",
      "type": [
        "integer",
        "null"
      ]
    }
  },
  "required": [
    "threadId"
  ],
  "title": "ThreadGoalSetParams",
  "type": "object"
}